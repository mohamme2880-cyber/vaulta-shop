
<!DOCTYPE html>
<html>
<head>
<title>Store</title>
<link rel="stylesheet" href="/style.css">
</head>

<body>

<h1 class="title">المتجر</h1>

<div class="products">

<% products.forEach(p=>{ %>

<div class="card">
<h2><%= p.name %></h2>
<p><%= p.desc %></p>
<span>$<%= p.price %></span>
<a href="/buy/<%= p.name %>" class="buy">شراء</a>
</div>

<% }) %>

</div>

</body>
</html>
